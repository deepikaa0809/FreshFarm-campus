rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (required, 'employee' | 'admin')
    //   - createdAt: string
    //
    // Collection: vegetables
    // Document ID: {vegetableId}
    // Fields:
    //   - name: string (required)
    //   - pricePerKg: number (required)
    //   - stockKg: number (required)
    //   - isAvailable: bool (required)
    //   - ...
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - userId: string (required)
    //   - items: list (required)
    //   - totalAmount: number (required)
    //   - status: string (required)
    //   - createdAt: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "ds20050908@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['employee', 'admin'] &&
             data.uid == request.auth.uid;
    }

    function isValidVegetable(data) {
      return data.keys().hasAll(['name', 'pricePerKg', 'stockKg', 'isAvailable']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.pricePerKg is number && data.pricePerKg >= 0 &&
             data.stockKg is number && data.stockKg >= 0 &&
             data.isAvailable is bool;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.items is list &&
             data.totalAmount is number &&
             data.status in ['pending', 'confirmed', 'ready', 'picked_up', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'employee';
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow write: if isAdmin();
    }

    match /vegetables/{vegetableId} {
      allow read: if true; // Public read access
      allow write: if isAdmin() && isValidVegetable(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.status == 'cancelled' && resource.data.status == 'pending');
    }
  }
}
